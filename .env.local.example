# ══════════════════════════════════════════════════════════════════════════════
# TripCopilot — environment variables reference
# Copy this file to .env.local and fill in your values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and anon key: Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key (server-only — NEVER expose to the browser).
# Settings → API → service_role in the Supabase dashboard.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Used for: AI itinerary parsing, trip health checks, airport guides, journals.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate a VAPID key pair once with:
#   npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is sent to the browser for push subscription.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=B...
VAPID_PRIVATE_KEY=...

# ── Flight data APIs ──────────────────────────────────────────────────────────
# AviationStack — live flight status (free tier: 100 req/month, HTTP only).
# Sign up at: https://aviationstack.com/signup/free
AVIATIONSTACK_API_KEY=your_key_here

# AeroDataBox via RapidAPI — international airport delays (non-USA).
# Free tier: 500 req/month. Sign up at: https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# Without this key, international airports will show no delay data.
AERODATABOX_RAPIDAPI_KEY=your_rapidapi_key_here

# FlightAware AeroAPI — real-time flight tracking and push webhooks.
# Required for gate-change and delay push notifications via FlightAware alerts.
# This value is also used as the shared secret token on the webhook URL.
# Generate a random string: openssl rand -hex 32
FLIGHTAWARE_API_KEY=your_flightaware_key_here
FLIGHTAWARE_WEBHOOK_SECRET=your_random_secret_here

# ── Payments (Mercado Pago) ───────────────────────────────────────────────────
# Used for Explorer/Pilot subscription checkout.
# Dashboard: https://www.mercadopago.com.ar/developers/
MP_ACCESS_TOKEN=APP_USR-...
# Webhook secret to validate IPN signatures (x-signature header).
# Set this to the secret configured in the MP webhook settings.
MP_WEBHOOK_SECRET=your_mp_webhook_secret_here

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Used for: welcome emails, friend-request notifications.
# Get your key at: https://resend.com/
RESEND_API_KEY=re_...

# ── Firebase Cloud Messaging (native push — iOS/Android via Capacitor) ────────
# Only needed if building the native app with Capacitor.
# Firebase project settings → Service accounts → Generate new private key.
FCM_PROJECT_ID=your_firebase_project_id
# Paste the entire service account JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Cron / internal auth ──────────────────────────────────────────────────────
# Bearer token that secures cron endpoints and n8n→app calls.
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# Public app URL — used to build absolute URLs in cron jobs and emails.
NEXT_PUBLIC_APP_URL=https://tripcopilot.app

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated emails that can access /admin and admin API routes.
ADMIN_EMAILS=you@example.com

# ── Test mode ─────────────────────────────────────────────────────────────────
# Set both to "true" to bypass authentication locally (Playwright / manual QA).
# The app throws on startup if TEST_MODE=true in NODE_ENV=production.
# TEST_MODE=true
# NEXT_PUBLIC_TEST_MODE=true
