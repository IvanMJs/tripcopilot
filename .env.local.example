# AviationStack API (free tier: 100 req/month, no HTTPS on free plan)
# Get your free key at: https://aviationstack.com/signup/free
AVIATIONSTACK_API_KEY=your_key_here

# AeroDataBox via RapidAPI (free tier: 500 req/month — international airport delays)
# Sign up at: https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# Without this key, international airports (non-USA) will show no delay data
AERODATABOX_RAPIDAPI_KEY=your_rapidapi_key_here
